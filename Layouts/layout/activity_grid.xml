<?xml version="1.0" encoding="utf-8"?>
<GridLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:columnCount="4"
    android:rowCount="6"
    android:padding="16dp"
    android:layout_gravity="center">

    <!-- Calculator Display Placeholder -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_columnSpan="4"
        android:background="#DDDDDD"
        android:text="0"
        android:textSize="36sp"
        android:gravity="end|center_vertical"
        android:padding="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- Row 1 -->
    <Button android:text="7" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="8" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="9" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="/" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>

    <!-- Row 2 -->
    <Button android:text="4" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="5" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="6" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="*" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>

    <!-- Row 3 -->
    <Button android:text="1" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="2" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="3" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="-" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>

    <!-- Row 4 -->
    <Button android:text="C" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="0" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="=" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>
    <Button android:text="+" android:layout_width="0dp" android:layout_columnWeight="1" android:layout_margin="4dp"/>

</GridLayout>
